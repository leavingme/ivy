# Ivy environment variables
# Copy this file to .env.local for local dev, and set the same keys in
# Vercel Dashboard → Project → Settings → Environment Variables.

# Required: API key for the LLM used by /api/extract-char.
# Primary: DeepSeek (https://platform.deepseek.com/)
# Legacy fallback: MiniMax (works if MINIMAX_* keys still set)
DEEPSEEK_API_KEY=your-key-here

# Optional overrides — defaults shown
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
