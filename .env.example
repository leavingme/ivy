# Ivy environment variables
# Copy this file to .env.local for local dev, and set the same keys in
# Vercel Dashboard → Project → Settings → Environment Variables.

# Required: API key for MiniMax-M3 LLM used by /api/extract-char.
# Get from your MiniMax account dashboard. Same value works for both
# MINIMAX_API_KEY (preferred) and MINIMAX_CN_API_KEY (alias).
MINIMAX_API_KEY=your-key-here

# Optional overrides — defaults shown
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M3
